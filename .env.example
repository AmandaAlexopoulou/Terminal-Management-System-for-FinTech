# ============================================================================
# .env.example — Template μεταβλητών περιβάλλοντος για το TMS
# ============================================================================
# Αντιγράψτε αυτό το αρχείο σε ".env" και συμπληρώστε πραγματικές τιμές:
#     cp .env.example .env
#
# ΠΡΟΣΟΧΗ: το .env (με τα πραγματικά credentials) ΔΕΝ ανεβαίνει ποτέ στο
# git — πρέπει να είναι στο .gitignore.
# ============================================================================

# ----------------------------------------------------------------------------
# MySQL
# ----------------------------------------------------------------------------
# Password του root χρήστη της MySQL (χρησιμοποιείται μόνο εσωτερικά /
# για διαχείριση, το app ΔΕΝ συνδέεται σαν root).
MYSQL_ROOT_PASSWORD=changeme_root_password

# Όνομα της database που θα δημιουργηθεί αυτόματα στο πρώτο boot.
MYSQL_DATABASE=tms_db

# Application user/password — αυτά χρησιμοποιεί το tms-api για να συνδεθεί
# (ΟΧΙ τον root).
MYSQL_USER=tms_user
MYSQL_PASSWORD=changeme_user_password

# Host/port που χρησιμοποιεί το tms-api για να βρει τη MySQL.
# Μέσα στο docker-compose network, το hostname ΕΙΝΑΙ το όνομα του service
# (δηλαδή "mysql"), ΟΧΙ localhost/127.0.0.1 — τα containers δεν μοιράζονται
# το ίδιο network namespace με τον host.
DB_HOST=mysql
DB_PORT=3306

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ----------------------------------------------------------------------------
# Flask app
# ----------------------------------------------------------------------------
FLASK_ENV=production
# Port στον οποίο ακούει το Flask ΜΕΣΑ στο container, και στον οποίο θα
# γίνεται mapped στο host (localhost:APP_PORT) μέσω του docker-compose.yml.
APP_PORT=5000
